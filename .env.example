# Required: OpenAI API key for embeddings (never commit real values)
OPENAI_API_KEY=

# Catalog files (required for a running API). Relative paths resolve to the repo root
# (the directory that contains pyproject.toml), not the shell cwd.
BOOKS_CSV_PATH=books_with_emotions.csv
TAGGED_DESCRIPTION_PATH=tagged_description.txt

# Comma-separated browser origins allowed for CORS (no spaces after commas recommended)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# dev exposes OpenAPI docs; prod disables /docs, /redoc, and /openapi.json
ENVIRONMENT=dev

# Optional: comma-separated hostnames for TrustedHostMiddleware (leave empty to disable)
TRUSTED_HOSTS=
